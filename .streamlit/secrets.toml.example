# Streamlit Cloud reads this file for app secrets.
# On Streamlit Cloud, you set these in the dashboard UI instead.
# This file is only a TEMPLATE — do NOT put real values here.
# Add the real values in: Streamlit Cloud → App Settings → Secrets

[azure_openai]
AZURE_OPENAI_API_KEY     = "your_api_key_here"
AZURE_OPENAI_API_VERSION = "2024-02-01"
AZURE_OPENAI_ENDPOINT    = "https://your-resource.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT  = "gpt-4o"
